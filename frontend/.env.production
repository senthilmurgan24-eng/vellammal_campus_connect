# Production environment — automatically loaded by `npm run build` (Vite mode: production)
# HTTPS / production domain. Commit this file; it contains no secrets.
# Set VITE_GOOGLE_CLIENT_ID via Vercel Dashboard > Settings > Environment Variables
# (never put secrets or real API keys here — this file is tracked by git).

VITE_API_BASE_URL=https://api.ranknovainstitute.com/api
VITE_WS_URL=wss://api.ranknovainstitute.com/ws-connect

# VITE_DEV_PROXY_TARGET is unused in production builds (Vite proxy only runs in dev server mode).
